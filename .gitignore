# Per-machine configuration. Start from configs/example.toml.
configs/*.toml
!configs/example.toml
!configs/athenak-gpu-smoke.toml
!configs/athenak-gpu-ma08-tiny.toml
!configs/athenak-gpu-ma08.toml
!configs/harris-sheet-athenapp.toml
!configs/harris-sheet-athenak-gpu.toml

# Disposable Athena++ build and simulation products.
build/
outputs/

# Python caches and local environments.
__pycache__/
*.py[cod]
.venv/
venv/

# Resolve Julia artifacts for the platform running the workflow.
Manifest.toml

# Editor and operating-system files.
.idea/
.vscode/
.DS_Store
Thumbs.db
